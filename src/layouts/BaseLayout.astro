---
const { title = "Taylor Portfolio" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style is:global>
      :root {
        --bg: #f4efe6;
        --bg-soft: #e7ddcf;
        --accent: #6f826a;
        --accent-soft: #a9c3ae;
        --accent-deep: #4e5e4b;
        --text: #2f312c;
        --text-muted: #6c6c61;
        --border: rgba(78, 94, 75, 0.2);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      .container {
        width: min(1100px, calc(100% - 2rem));
        margin: 0 auto;
      }

      header {
        padding: 1rem 0;
        border-bottom: 1px solid var(--border);
        background: rgba(244, 239, 230, 0.95);
      }

      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
      }

      .brand {
        font-size: 1.4rem;
        font-weight: bold;
        color: var(--accent-deep);
        text-decoration: none;
      }

      .nav-links {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .nav-links a {
        text-decoration: none;
        color: var(--text-muted);
        font-weight: 600;
      }

      main {
        padding: 3rem 0;
      }

      footer {
        padding: 2rem 0 3rem;
        border-top: 1px solid var(--border);
        color: var(--text-muted);
      }

      .eyebrow {
        text-transform: uppercase;
        letter-spacing: 0.06em;
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--accent-deep);
      }

      .lead {
        color: var(--text-muted);
        max-width: 60ch;
      }

      .panel,
      .card,
      .project-card,
      .cv-block {
        background: var(--bg-soft);
        border: 1px solid var(--border);
        border-radius: 22px;
        padding: 1.5rem;
      }

      .split-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1.5rem;
      }

      .project-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.25rem;
        margin-top: 2rem;
      }

      .cv-grid {
        display: grid;
        gap: 1.25rem;
        margin-top: 2rem;
      }

      .button-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .button {
        display: inline-block;
        padding: 0.85rem 1.2rem;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        border: 1px solid transparent;
      }

      .button-primary {
        background: var(--accent);
        color: white;
      }

      .button-secondary {
        border-color: var(--border);
        color: var(--accent-deep);
        background: transparent;
      }

      h1, h2, h3 {
        margin-top: 0;
        color: var(--accent-deep);
      }

      h1 {
        font-size: clamp(2.4rem, 5vw, 4.5rem);
        line-height: 1.05;
      }

      .clean-list {
        padding-left: 1.2rem;
        margin: 0;
      }

      .contact-links a {
        display: block;
        margin-bottom: 0.8rem;
        color: var(--accent-deep);
        font-weight: 700;
        text-decoration: none;
      }

      .muted {
        color: var(--text-muted);
      }

      @media (max-width: 900px) {
        .split-grid,
        .project-grid {
          grid-template-columns: 1fr;
        }

        nav {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="container">
        <nav>
          <a href="/" class="brand">Taylor Heathcote - Portfolio</a>
          <div class="nav-links">
            <a href="/">Home</a>
            <a href="/about">About</a>
            <a href="/projects">Projects</a>
            <a href="/cv">CV</a>
            <a href="/contact">Contact</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">
        <p>© 2026 Taylor Heathcote.</p>
      </div>
    </footer>
  </body>
</html>