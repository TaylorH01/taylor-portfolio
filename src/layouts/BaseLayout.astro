---
import "../styles/global.css";

const {
  title = "Taylor Heathcote | Game Design & Production",
  description = "Creative portfolio for Taylor Heathcote — game design, production, and thoughtful creative work.",
  currentPage = ""
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-48x48.png" sizes="48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#F4EFE6" />
  </head>

  <body>
    <header>
      <div class="container">
        <nav>
          <a href="/" class="brand-block">
            <span class="brand">Taylor Heathcote - Portfolio</span>
            <span class="brand-subtitle">Game Design • Media Production • Creative Generalism</span>
          </a>
          <div class="nav-links">
             <a href="/" class={currentPage === "home" ? "active" : ""}>Home</a>
              <a href="/about" class={currentPage === "about" ? "active" : ""}>About</a>
              <a href="/blog" class={currentPage === "blog" ? "active" : ""}>Blog</a>
              <a href="/projects" class={currentPage === "projects" ? "active" : ""}>Projects</a>
              <a href="/cv" class={currentPage === "cv" ? "active" : ""}>CV</a>
              <a href="/contact" class={currentPage === "contact" ? "active" : ""}>Contact</a>
            </div>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">
        <p>© 2026 Taylor Heathcote.</p>
      </div>
    </footer>
  </body>
</html>