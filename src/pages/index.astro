---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const latestPosts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((post: CollectionEntry<"blog">) => !post.data.draft)
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.date.getTime() - a.data.date.getTime()
  )
  .slice(0, 3);
---

<BaseLayout title="Taylor Heathcote | Game Design & Production" currentPage="home">
<section class="home-top-grid">
  <section class="panel intro-panel">
    <h3>Hi, I’m Taylor, a creative generalist with a background in game development and digital media production.</h3>

    <p class="lead">
      This is a general paragraph placeholder that I’ll fill in later. This
      will cover a general introduction of me, my interests, as well as a
      light covering of my background and what kind of working I produce.
      Anything else in this paragraph may also be a generally good explanation
      about me Taylor Heathcote as well as any relevant information that I
      think might be useful to know at a glance!
    </p>

    <div class="button-row">
      <a href="/projects" class="button button-primary">View Projects</a>
      <a href="/cv" class="button button-primary">Read CV</a>
    </div>
  </section>

  <div class="showcase-column">
    <section class="panel showcase-video-panel">
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/jNAhLgSS61U"
          title="Portfolio showcase video"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
    </section>

    <section class="panel showcase-text-panel">
      <h2>Portfolio Showcase</h2>
      <p>
        Over the course of ~8 years of study I’ve ventured down many
        different creative paths. I love to explore different projects,
        formats and styles and create quality experiences!
      </p>
    </section>
  </div>
</section>

<section class="panel feed-panel">
  <div class="feed-header">
    <h2 class="feed-title">Blog Posts</h2>
    <a href="/blog" class="button button-primary feed-view-all">View All</a>
  </div>

  <div class="feed-grid">
    {latestPosts.map((post: CollectionEntry<"blog">) => (
      <article class="feed-card">
        <div class="feed-thumb">
          <img src={post.data.thumbnail} alt={post.data.title} />
        </div>

        <div class="feed-copy">
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </div>

        <div class="feed-actions">
          <a href={`/blog/${post.id}`} class="button button-primary feed-button">Read</a>
        </div>
      </article>
    ))}
  </div>
</section>
</BaseLayout>