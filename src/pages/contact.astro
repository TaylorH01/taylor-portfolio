---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Taylor Portfolio">
  <div class="split-grid">
    <section class="card">
      <p class="eyebrow">Contact</p>
      <h1>Let’s talk.</h1>
      <p>
        Whether it’s a job opportunity, collaboration, or just a reason to
        talk about creative work, I’m easy to reach.
      </p>
    </section>

    <section class="card">
      <p class="eyebrow">Details</p>
      <div class="contact-links">
        <a href="mailto:your-email@example.com">your-email@example.com</a>
        <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>
        <a href="/cv">View CV</a>
      </div>
      <p class="muted">
        Replace the placeholder email and LinkedIn link with your real details later.
      </p>
    </section>
  </div>
</BaseLayout>