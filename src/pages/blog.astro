---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const posts: CollectionEntry<"blog">[] = (await getCollection("blog"))
  .filter((post: CollectionEntry<"blog">) => !post.data.draft)
  .sort(
    (a: CollectionEntry<"blog">, b: CollectionEntry<"blog">) =>
      b.data.date.getTime() - a.data.date.getTime()
  );

const latestPost = posts[0];
---

<BaseLayout title="Blog | Taylor Heathcote" currentPage="blog">
  <section class="panel blog-intro-panel">
    <h1>Blog</h1>

    <p class="lead">
      Development notes, project reflections, portfolio progress, and longer-form
      writing as the site continues to grow.
    </p>

    {latestPost && (
      <p class="blog-intro-meta">
        Latest post:
        <a href={`/blog/${latestPost.id}`}>{latestPost.data.title}</a>
      </p>
    )}
  </section>

  <section class="panel blog-list-panel">
    <div class="blog-list-header">
      <div class="blog-list-heading">
        <h2>Posts</h2>
        <p class="blog-list-subtext">
          Writing, updates, and works in progress collected in one place.
        </p>
      </div>

      <p class="blog-post-count">{posts.length} posts found</p>
    </div>

    <div class="blog-list-grid">
      {posts.map((post: CollectionEntry<"blog">) => (
        <article class="blog-post-card">
          <a href={`/blog/${post.id}`} class="blog-post-card-link">
            <div class="blog-post-thumb">
              <img src={post.data.thumbnail} alt={post.data.title} />
            </div>
          </a>

          <div class="blog-post-copy">
            <p class="blog-post-date">
              {post.data.date.toLocaleDateString("en-GB", {
                day: "numeric",
                month: "long",
                year: "numeric",
              })}
            </p>

            <h3>
              <a href={`/blog/${post.id}`} class="blog-post-title-link">
                {post.data.title}
              </a>
            </h3>

            <p>{post.data.description}</p>
          </div>

          <div class="blog-post-actions">
            <a
              href={`/blog/${post.id}`}
              class="button button-primary blog-read-button"
            >
              Read Post
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>