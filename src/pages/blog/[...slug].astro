---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter((post: CollectionEntry<"blog">) => !post.data.draft);

  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} | Blog | Taylor Heathcote`}
  description={post.data.description}
  currentPage="blog"
>
  <section class="blog-post-page">
    <div class="panel">
      <div class="blog-post-topbar">
        <a href="/blog" class="button button-secondary">← Back to Blog</a>
      </div>

      <div class="blog-post-hero">
        <div class="blog-post-hero-copy">
          <p class="blog-post-date">
            {post.data.date.toLocaleDateString("en-GB", {
              day: "numeric",
              month: "long",
              year: "numeric",
            })}
          </p>

          <h1>{post.data.title}</h1>
          <p class="lead">{post.data.description}</p>
        </div>

        <div class="blog-post-hero-image">
          <img
            src={post.data.thumbnail}
            alt={post.data.title}
            loading="eager"
          />
        </div>
      </div>

      <article class="blog-post-body">
        <Content />
      </article>
    </div>
  </section>
</BaseLayout>