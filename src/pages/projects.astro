---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const projects: CollectionEntry<"projects">[] = (await getCollection("projects"))
  .filter((project: CollectionEntry<"projects">) => !project.data.draft)
  .sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
      a.data.order - b.data.order
  );

const featuredProjects = projects.filter((project) => project.data.bucket === "featured");
const collectionProjects = projects.filter((project) => project.data.bucket === "collection");
const currentProjects = projects.filter((project) => project.data.bucket === "current");

const leadProject = featuredProjects[0] ?? projects[0];
---

<BaseLayout
  title="Projects | Taylor Heathcote"
  description="Selected game design, QA, UI/UX, and creative portfolio work by Taylor Heathcote."
  currentPage="projects"
>
  <section class="projects-page">
    <div class="projects-hero panel">
      <div class="projects-hero-layout">
        <div class="projects-hero-copy">
          <p class="eyebrow projects-kicker">Project Record</p>
          <h1>Selected work, design collections, and ongoing development.</h1>
          <p class="lead projects-lead">
            This is a hand-picked selection of some of my work.
            You'll find finished projects, Collections & things I'm currently working on.
          </p>

          <div class="projects-chip-row" aria-label="Project disciplines">
            <span class="projects-chip">Game Design</span>
            <span class="projects-chip">Level Design</span>
            <span class="projects-chip">UI / UX Design</span>
            <span class="projects-chip">Writing</span>
            <span class="projects-chip">In Development</span>
          </div>
        </div>

        <aside class="projects-hero-record card">
          <p class="sheet-label">Archive Summary</p>

          <div class="projects-record-grid">
            <div class="projects-record-item">
              <span class="projects-record-number">{projects.length}</span>
              <span class="projects-record-label">Total Projects</span>
            </div>

            <div class="projects-record-item">
              <span class="projects-record-number">{featuredProjects.length}</span>
              <span class="projects-record-label">Featured Work</span>
            </div>

            <div class="projects-record-item">
              <span class="projects-record-number">{collectionProjects.length}</span>
              <span class="projects-record-label">Collections</span>
            </div>

            <div class="projects-record-item">
              <span class="projects-record-number">{currentProjects.length}</span>
              <span class="projects-record-label">In Progress</span>
            </div>
          </div>

          {leadProject && (
            <div class="projects-hero-highlight">
              <p class="sheet-label">Currently Highlighted</p>
              <h2 class="projects-highlight-title">{leadProject.data.title}</h2>
              <p class="projects-highlight-copy">{leadProject.data.description}</p>

              <div class="project-link-row">
                <a class="button button-primary" href={`/projects/${leadProject.id}/`}>
                  View Highlighted Project
                </a>
              </div>
            </div>
          )}
        </aside>
      </div>
    </div>

    <section class="projects-section projects-featured-section">
      <div class="projects-featured-head">
        <div class="projects-featured-top">
          <p class="sheet-label">Showcase Pieces</p>
          <span class="projects-section-count">{featuredProjects.length}</span>
        </div>

        <h2>Featured Work</h2>
        <p class="projects-section-copy">
          Larger showcase pieces presented with more context, stronger hierarchy, and clearer role definition.
        </p>
      </div>

      <div class="projects-featured-list">
        {featuredProjects.map((project) => (
          <article class="projects-feature-card card">
            <a
              class="projects-feature-media"
              href={`/projects/${project.id}/`}
              aria-label={`Open ${project.data.title}`}
            >
              <img
                src={project.data.thumbnail}
                alt={project.data.shortTitle ?? project.data.title}
                class="projects-feature-image"
                loading="lazy"
              />
            </a>

            <div class="projects-feature-copy">
              <div class="projects-meta-row">
                <span class="projects-category">{project.data.category}</span>
                <span class="projects-status">{project.data.status}</span>
              </div>

              <h2 class="projects-card-title">
                <a href={`/projects/${project.id}/`}>{project.data.title}</a>
              </h2>

              <p class="projects-card-description">{project.data.description}</p>

              {project.data.roles.length > 0 && (
                <div class="project-role-list" aria-label={`${project.data.title} roles`}>
                  {project.data.roles.map((role) => (
                    <span class="project-role-pill">{role}</span>
                  ))}
                </div>
              )}

              <div class="project-link-row">
                <a class="button button-primary" href={`/projects/${project.id}/`}>
                  View Project
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="projects-lower-grid">
      <section class="projects-section-shell card">
        <div class="projects-section-shell-head">
          <div class="projects-section-shell-top">
            <p class="sheet-label">Supporting Archive</p>
            <span class="projects-section-count">{collectionProjects.length}</span>
          </div>

          <h2>Collections & Supporting Work</h2>
          <p class="projects-section-copy">
            Grouped and supporting work collected into dedicated pages.
          </p>
        </div>

        <div class="projects-collection-grid">
          {collectionProjects.map((project) => (
            <article class="projects-collection-card card">
              <div class="projects-meta-row">
                <span class="projects-category">{project.data.category}</span>
                {project.data.year && <span class="projects-year">{project.data.year}</span>}
              </div>

              <h2 class="projects-card-title">
                <a href={`/projects/${project.id}/`}>{project.data.title}</a>
              </h2>

              <p class="projects-card-description">{project.data.description}</p>

              <a class="button button-primary" href={`/projects/${project.id}/`}>
                View Project
              </a>
            </article>
          ))}
        </div>
      </section>

      <section class="projects-section-shell card">
        <div class="projects-section-shell-head">
          <div class="projects-section-shell-top">
            <p class="sheet-label">Ongoing Work</p>
            <span class="projects-section-count">{currentProjects.length}</span>
          </div>

          <h2>In Development</h2>
          <p class="projects-section-copy">
            Ongoing and unreleased personal projects I'm still working on!
          </p>
        </div>

        <div class="projects-current-grid">
          {currentProjects.map((project) => (
            <article class="projects-current-card card">
              <div class="projects-current-top">
                <span class="projects-category">{project.data.category}</span>
                <span class="projects-status projects-status-soft">{project.data.status}</span>
              </div>

              <h2 class="projects-card-title">
                <a href={`/projects/${project.id}/`}>{project.data.title}</a>
              </h2>

              <p class="projects-card-description">{project.data.description}</p>

              <a class="button button-primary" href={`/projects/${project.id}/`}>
                View Project
              </a>
            </article>
          ))}
        </div>
      </section>
    </section>
  </section>
</BaseLayout>