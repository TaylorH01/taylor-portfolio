---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

const projects: CollectionEntry<"projects">[] = (await getCollection("projects"))
  .filter((project: CollectionEntry<"projects">) => !project.data.draft)
  .sort(
    (a: CollectionEntry<"projects">, b: CollectionEntry<"projects">) =>
      a.data.order - b.data.order
  );

const featuredProjects = projects.filter((project) => project.data.bucket === "featured");
const collectionProjects = projects.filter((project) => project.data.bucket === "collection");
const currentProjects = projects.filter((project) => project.data.bucket === "current");
---

<BaseLayout
  title="Projects | Taylor Heathcote"
  description="Detailed project work spanning game design, level design, UI/UX, writing, and in-development creative work."
  currentPage="projects"
>
  <section class="projects-page">
    <section class="panel projects-hero-board">
      <div class="projects-hero-grid">
        <div class="projects-hero-copy">
          <p class="eyebrow">Projects</p>
          <h1 class="projects-hero-title">
            Selected work, design collections, and ongoing development.
          </h1>
          <p class="lead">
            A curated look at the projects that best show how I think, what I
            contribute, and the kinds of creative problems I enjoy solving.
          </p>

          <div class="projects-hero-tags">
            <span class="projects-hero-tag">Game Design</span>
            <span class="projects-hero-tag">Level Design</span>
            <span class="projects-hero-tag">UI / UX Design</span>
            <span class="projects-hero-tag">Writing</span>
            <span class="projects-hero-tag">In Development</span>
          </div>
        </div>

        <aside class="projects-hero-record panel">
          <p class="sheet-label">Project Record</p>

          <dl class="projects-record-list">
            <div>
              <dt>Featured Work</dt>
              <dd>{featuredProjects.length}</dd>
            </div>
            <div>
              <dt>Collections</dt>
              <dd>{collectionProjects.length}</dd>
            </div>
            <div>
              <dt>In Progress</dt>
              <dd>{currentProjects.length}</dd>
            </div>
          </dl>

          <div class="projects-record-tags">
            <span class="projects-record-tag">Showcase Pieces</span>
            <span class="projects-record-tag">Collections</span>
            <span class="projects-record-tag">In Progress</span>
          </div>
        </aside>
      </div>
    </section>

    <section class="panel projects-showcase-panel">
      <div class="projects-section-header">
        <div>
          <h2>Featured Work</h2>
          <p class="projects-section-subtext">
            Larger projects and stronger showcase pieces presented with more emphasis.
          </p>
        </div>
      </div>

      <div class="project-showcase-stack">
        {featuredProjects.map((project) => (
          <article class="project-showcase-card">
            <a href={`/projects/${project.id}`} class="project-showcase-thumb-link">
              <div class="project-showcase-thumb">
                <img src={project.data.thumbnail} alt={project.data.title} />
              </div>
            </a>

            <div class="project-showcase-copy">
              <p class="project-kicker">{project.data.category}</p>
              <h2 class="project-card-title project-card-title-showcase">
                <a href={`/projects/${project.id}`} class="project-title-link">
                  {project.data.title}
                </a>
              </h2>
              <p class="project-status">{project.data.status}</p>
              <p class="project-description">{project.data.description}</p>

              <div class="project-role-list">
                {project.data.roles.map((role) => (
                  <span class="project-role-chip">{role}</span>
                ))}
              </div>

              <div class="project-showcase-actions">
                <a href={`/projects/${project.id}`} class="button button-primary">
                  View Project
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="projects-lower-grid">
      <section class="panel projects-section-panel">
        <div class="projects-section-header">
          <div>
            <h2>Collections & Supporting Work</h2>
            <p class="projects-section-subtext">
              Focused collections and smaller supporting pieces that still deserve dedicated pages.
            </p>
          </div>
        </div>

        <div class="project-support-list">
          {collectionProjects.map((project) => (
            <article class="project-support-card">
              <a href={`/projects/${project.id}`} class="project-support-thumb-link">
                <div class="project-support-thumb">
                  <img src={project.data.thumbnail} alt={project.data.title} />
                </div>
              </a>

              <div class="project-support-copy">
                <p class="project-kicker">{project.data.category}</p>
                <h2 class="project-card-title project-card-title-small">
                  <a href={`/projects/${project.id}`} class="project-title-link">
                    {project.data.title}
                  </a>
                </h2>
                <p class="project-description">{project.data.description}</p>
              </div>

              <div class="project-support-actions">
                <a href={`/projects/${project.id}`} class="button button-primary">
                  View Project
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="panel projects-section-panel projects-current-panel">
        <div class="projects-section-header">
          <div>
            <h2>In Development</h2>
            <p class="projects-section-subtext">
              Ongoing and unreleased work that is still being built and refined.
            </p>
          </div>
        </div>

        <div class="project-current-list">
          {currentProjects.map((project) => (
            <article class="project-current-row">
              <div class="project-current-row-main">
                <p class="project-kicker">{project.data.category}</p>
                <h2 class="project-card-title project-card-title-small">
                  <a href={`/projects/${project.id}`} class="project-title-link">
                    {project.data.title}
                  </a>
                </h2>
                <p class="project-status">{project.data.status}</p>
                <p class="project-description">{project.data.description}</p>
              </div>

              <div class="project-current-row-side">
                <span class="project-current-flag">In Development</span>
                <a href={`/projects/${project.id}`} class="button button-primary">
                  View Project
                </a>
              </div>
            </article>
          ))}
        </div>
      </section>
    </section>
  </section>
</BaseLayout>